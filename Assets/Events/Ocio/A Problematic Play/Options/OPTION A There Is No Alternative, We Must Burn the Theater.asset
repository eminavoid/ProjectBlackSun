  m_Name: OPTION A There Is No Alternative, We Must Burn the Theater
  m_EditorClassIdentifier: Assembly-CSharp::Option
  title: There Is No Alternative, We Must Burn the Theater
  description: 'COST: 10 Flock'
  icon: {fileID: 0}
