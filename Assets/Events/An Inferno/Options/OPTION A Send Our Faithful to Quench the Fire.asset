  m_Name: OPTION A Send Our Faithful to Quench the Fire
  m_EditorClassIdentifier: Assembly-CSharp::Option
  title: Send Our Faithful to Quench the Fire
  description: 'COST: 20 Flock'
  icon: {fileID: 0}
  modules:
  - rid: 107151340257149004
  - rid: 107151343762276434
  endsQuestline: 1
  followUpSeeds: []
  references:
