  m_Name: OPTION A We Must Protect Our Temples at All Costs!
  m_EditorClassIdentifier: Assembly-CSharp::Option
  title: We Must Protect Our Temples at All Costs!
  description: 'COST: 40 Flock'
  icon: {fileID: 0}
  modules:
  - rid: 107151359355650107
  - rid: 107151359355650108
  endsQuestline: 1
