  m_Name: OPTION D Burn Him at the Stake! None May Speak for the Beholder!
  m_EditorClassIdentifier: Assembly-CSharp::Option
  title: Burn Him at the Stake! None May Speak for the Beholder!
  description: No cost
  icon: {fileID: 0}
