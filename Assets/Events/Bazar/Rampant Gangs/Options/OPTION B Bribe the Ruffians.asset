  m_Name: OPTION B Bribe the Ruffians
  m_EditorClassIdentifier: Assembly-CSharp::Option
  title: Bribe the Ruffians
  description: 'COST: 50 Wealth'
  icon: {fileID: 0}
  modules:
  - rid: 107151359355650052
  - rid: 107151359355650053
